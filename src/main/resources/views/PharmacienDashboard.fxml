<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="1200.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.PharmacienDashboardController">
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="app-header">
        <Label text="⚕️ Pharmacie Centrale — Terminal Applicatif" textFill="WHITE">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS" />
        <Button onAction="#handleLogout" styleClass="btn-danger" text="🔒 Déconnexion" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="🛒 Caisse &amp; Dispensation">
                <HBox spacing="25.0" style="-fx-padding: 25 20 20 20;">
                    <VBox spacing="15.0" prefWidth="380.0" styleClass="sidebar-card">
                        <Label text="📝 Nouvelle Ligne d'Achat" styleClass="card-title" />

                        <Label text="Associer un Client :" styleClass="field-label"/>
                        <ComboBox fx:id="clientCombo" promptText="Client de passage..." prefWidth="380.0" />

                        <Label text="Sélectionner le Médicament :" styleClass="field-label"/>
                        <ComboBox fx:id="medicamentVenteCombo" promptText="Rechercher une référence..." prefWidth="380.0" />

                        <Label text="Quantité à délivrer :" styleClass="field-label"/>
                        <TextField fx:id="quantiteVenteField" promptText="Ex: 2" />

                        <Button onAction="#handleAjouterAuPanier" text="➕ Ajouter au Panier" prefWidth="380.0" styleClass="btn-primary"/>
                        <Label fx:id="venteMessageLabel" textFill="#ef4444" wrapText="true" style="-fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                        <Label text="🛒 Panier Patient Actuel" styleClass="section-title" />
                        <TableView fx:id="panierTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="panierNomCol" prefWidth="320.0" text="Désignation de la Référence" />
                                <TableColumn fx:id="panierQteCol" prefWidth="120.0" text="Quantité" />
                                <TableColumn fx:id="panierPrixCol" prefWidth="180.0" text="Sous-Total (Dhs)" />
                            </columns>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="25.0" styleClass="total-bar">
                            <Label text="NET A PAYER :"><font><Font name="System Bold" size="16.0"/></font></Label>
                            <Label fx:id="totalLabel" text="0.00 Dhs" textFill="#10b981"><font><Font name="System Bold" size="24.0"/></font></Label>
                            <Button onAction="#handleValiderVente" text="💾 Encaisser la Transaction" prefWidth="220.0" prefHeight="42.0" styleClass="btn-success"/>
                        </HBox>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="📦 Gestion de l'Inventaire">
                <HBox spacing="25.0" style="-fx-padding: 25 20 20 20;">
                    <VBox spacing="15.0" prefWidth="320.0" styleClass="sidebar-card">
                        <Label text="📥 Entrée de Produit" styleClass="card-title" />
                        <TextField fx:id="nomField" promptText="Nom commercial" />
                        <TextField fx:id="categorieField" promptText="Classe thérapeutique" />
                        <TextField fx:id="prixField" promptText="Prix public (Dhs)" />
                        <TextField fx:id="stockField" promptText="Quantité reçue" />
                        <DatePicker fx:id="dateExpirationPicker" promptText="Date de péremption" prefWidth="320.0" />
                        <Button onAction="#handleAjouterMedicament" text="Valider Entrée Stock" prefWidth="320.0" styleClass="btn-success"/>
                        <Label fx:id="stockMessageLabel" textFill="#ef4444" wrapText="true"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="15.0">
                        <Label text="📦 Inventaire des Stocks Actifs (Les stocks &lt; 5 s'affichent automatiquement en rouge)" styleClass="section-title" />
                        <TableView fx:id="medicamentsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="nomCol" prefWidth="240.0" text="Nom du Médicament" />
                                <TableColumn fx:id="categorieCol" prefWidth="160.0" text="Catégorie" />
                                <TableColumn fx:id="prixCol" prefWidth="120.0" text="Prix Unitaire" />
                                <TableColumn fx:id="stockCol" prefWidth="110.0" text="Stock Disponible" />
                                <TableColumn fx:id="expirationCol" prefWidth="140.0" text="Échéance Expiration" />
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="📜 Journal des Ventes">
                <VBox spacing="15.0" style="-fx-padding: 25 20 20 20;">
                    <Label text="📜 Historique Complet des Ventes Encaissées" styleClass="section-title" />
                    <TableView fx:id="historiqueTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="histIdCol" prefWidth="120.0" text="N° Facture" />
                            <TableColumn fx:id="histDateCol" prefWidth="220.0" text="Date de Vente" />
                            <TableColumn fx:id="histClientCol" prefWidth="280.0" text="Client Bénéficiaire" />
                            <TableColumn fx:id="histTotalCol" prefWidth="180.0" text="Total Facturé (Dhs)" />
                        </columns>
                    </TableView>
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Button onAction="#chargerHistoriqueVentes" text="🔄 Rafraîchir la Liste" styleClass="btn-info"/>
                        <Button onAction="#handleImprimerFacture" text="🖨️ Imprimer le Reçu PDF" styleClass="btn-warning"/>
                        <Label fx:id="pdfMessageLabel" textFill="#10b981" style="-fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="👥 Répertoire Clients">
                <HBox spacing="25.0" style="-fx-padding: 25 20 20 20;">
                    <VBox spacing="15.0" prefWidth="320.0" styleClass="sidebar-card">
                        <Label text="👤 Fiche Nouveau Client" styleClass="card-title" />
                        <TextField fx:id="clientNomField" promptText="Nom Complet (Obligatoire)" />
                        <TextField fx:id="clientTelField" promptText="N° de Téléphone" />
                        <TextField fx:id="clientEmailField" promptText="Adresse Email" />
                        <Button onAction="#handleAjouterClient" text="Enregistrer Fiche Client" prefWidth="320.0" styleClass="btn-success"/>
                        <Label fx:id="clientMessageLabel" textFill="#ef4444" wrapText="true"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="15.0">
                        <Label text="👥 Base Nominative des Clients" styleClass="section-title" />
                        <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="clientIdCol" prefWidth="80.0" text="ID" />
                                <TableColumn fx:id="clientNomCol" prefWidth="300.0" text="Nom Complet" />
                                <TableColumn fx:id="clientTelCol" prefWidth="180.0" text="Téléphone" />
                                <TableColumn fx:id="clientEmailCol" prefWidth="250.0" text="Adresse Email" />
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>