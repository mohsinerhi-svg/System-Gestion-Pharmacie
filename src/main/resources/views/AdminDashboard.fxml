<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AdminDashboardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Tableau de Bord Administrateur" textFill="#2e8b57">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS" /> <Button onAction="#handleLogout" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold;" text="Se déconnecter" />
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">

        <VBox spacing="15.0" prefWidth="250.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
            <Label text="Ajouter un Utilisateur"><font><Font name="System Bold" size="16.0"/></font></Label>

            <TextField fx:id="newUsernameField" promptText="Nom d'utilisateur" />
            <PasswordField fx:id="newPasswordField" promptText="Mot de passe" />
            <ComboBox fx:id="roleComboBox" promptText="Choisir un rôle" prefWidth="250.0" />

            <Button onAction="#handleAjouterUtilisateur" text="Ajouter" prefWidth="250.0" style="-fx-background-color: #0275d8; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Label fx:id="messageLabel" textFill="RED" wrapText="true"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="10.0">
            <Label text="Liste des Utilisateurs"><font><Font name="System Bold" size="16.0"/></font></Label>

            <TableView fx:id="utilisateursTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                    <TableColumn fx:id="usernameCol" prefWidth="200.0" text="Nom d'utilisateur" />
                    <TableColumn fx:id="roleCol" prefWidth="150.0" text="Rôle" />
                </columns>
            </TableView>
        </VBox>

    </HBox>
</VBox>