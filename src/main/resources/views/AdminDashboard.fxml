<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.AdminDashboardController">

    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #343a40; -fx-padding: 20;">
        <Label text="Tableau de Bord Administrateur" textFill="WHITE"><font><Font name="System Bold" size="24.0"/></font></Label>
        <HBox HBox.hgrow="ALWAYS" />
        <Button onAction="#handleLogout" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold;" text="Se déconnecter" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="👥 Gestion des Utilisateurs">
                <HBox spacing="20.0" style="-fx-padding: 20;">
                    <VBox spacing="15.0" prefWidth="250.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
                        <Label text="Ajouter un Utilisateur"><font><Font name="System Bold" size="16.0"/></font></Label>
                        <TextField fx:id="newUsernameField" promptText="Nom d'utilisateur" />
                        <PasswordField fx:id="newPasswordField" promptText="Mot de passe" />
                        <ComboBox fx:id="roleComboBox" promptText="Choisir un rôle" prefWidth="250.0" />
                        <Button onAction="#handleAjouterUtilisateur" text="Créer le compte" prefWidth="250.0" style="-fx-background-color: #0275d8; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label fx:id="messageLabel" textFill="RED" wrapText="true"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="10.0">
                        <Label text="Liste des Utilisateurs"><font><Font name="System Bold" size="16.0"/></font></Label>
                        <TableView fx:id="utilisateursTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="usernameCol" prefWidth="200.0" text="Nom d'utilisateur" />
                                <TableColumn fx:id="roleCol" prefWidth="150.0" text="Rôle" />
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="📊 Statistiques &amp; Alertes">
                <VBox spacing="20.0" style="-fx-padding: 20;">

                    <HBox spacing="20.0">
                        <VBox alignment="CENTER" style="-fx-background-color: #28a745; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="Chiffre d'Affaires Total Encaissé" textFill="WHITE"><font><Font name="System Bold" size="18.0"/></font></Label>
                            <Label fx:id="caTotalLabel" text="0.00 €" textFill="WHITE"><font><Font name="System Bold" size="36.0"/></font></Label>
                        </VBox>
                    </HBox>

                    <Label text="⚠️ Médicaments en Rupture de Stock (Moins de 5 unités)" textFill="#d9534f"><font><Font name="System Bold" size="18.0"/></font></Label>
                    <TableView fx:id="ruptureTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #d9534f;">
                        <columns>
                            <TableColumn fx:id="rupIdCol" prefWidth="100.0" text="ID" />
                            <TableColumn fx:id="rupNomCol" prefWidth="400.0" text="Nom du Médicament" />
                            <TableColumn fx:id="rupStockCol" prefWidth="150.0" text="Stock Restant" />
                        </columns>
                    </TableView>

                    <Button onAction="#chargerStatistiques" text="🔄 Rafraîchir les statistiques" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>